{
  "name": "portugalstore",
  "version": "1.0.0",
  "description": "Mockup of PortugalStore website with Express backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "NODE_ENV=production pm2 start ecosystem.config.js --env production",
    "prod:stop": "pm2 stop ecosystem.config.js",
    "prod:restart": "pm2 restart ecosystem.config.js",
    "prod:delete": "pm2 delete ecosystem.config.js",
    "prod:logs": "pm2 logs portugalstore",
    "prod:monit": "pm2 monit",
    "build:tailwind": "tailwindcss -i ./backend/admin/admin-tailwind.css -o ./backend/admin/dist/admin-tailwind.css --watch",
    "build:tailwind:prod": "tailwindcss -i ./backend/admin/admin-tailwind.css -o ./backend/admin/dist/admin-tailwind.css --minify",
    "tailwind:watch": "npm run build:tailwind",
    "tailwind:build": "npm run build:tailwind:prod",
    "preprod": "npm run tailwind:build",
    "build": "echo 'No build step required for this project'",
    "migrate:coupons-schema": "node scripts/apply-coupons-schema-patch.js",
    "test": "jest",
    "lint": "echo 'Add linting if needed'"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.3.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsdom": "^29.0.1",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "mongodb-memory-server": "^10.4.3",
    "mongoose": "^9.3.1",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.3",
    "openai": "^6.41.0",
    "pdfkit": "^0.13.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.0",
    "@turf/turf": "^6.5.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "jest": "^30.3.0",
    "nodemon": "^2.0.22",
    "pm2": "^5.3.0",
    "postcss": "^8.5.14",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
