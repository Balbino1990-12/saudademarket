# Environment Configuration for PortugalStore
# Copy this file to .env and fill in your actual values.

# Core app
NODE_ENV=production
PORT=3000
APP_URL=https://your-domain.com
TRUST_PROXY=true
COOKIE_DOMAIN=.your-domain.com

# Security
SESSION_SECRET=replace-with-a-long-random-string
JWT_SECRET=replace-with-a-long-random-string

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=portugalstore

# SMTP / email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@your-domain.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@your-domain.com
CONTACT_ADMIN_EMAIL=admin@your-domain.com

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Shopify / optional integrations
SHOP_NAME=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_...
SHOPIFY_STOREFRONT_TOKEN=...

# OAuth / optional integrations
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
FACEBOOK_APP_ID=...
FACEBOOK_APP_SECRET=...
APPLE_CLIENT_ID=...
APPLE_TEAM_ID=...
APPLE_KEY_ID=...
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# AI / optional
OPENAI_API_KEY=...

# Performance / limits
COMPRESSION_LEVEL=6
SESSION_TTL=86400
CACHE_TTL_PRODUCTS=3600
CACHE_TTL_CATEGORIES=3600
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info